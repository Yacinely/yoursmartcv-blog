---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const posts = (await getCollection("blog"))
  .filter((post) => post.id.startsWith("en/"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const getSlug = (post) =>
  post.id.replace(/^en\//, "").replace(/\.(md|mdx)$/, "");
---

<!doctype html>
<html lang="en">
	  <head>
	  <BaseHead
		title="YourSmartCV – Blog"
		description="Practical guides to beat ATS, tailor your CV with AI, and write strong cover letters."
	  />
	  <link rel="alternate" hreflang="en" href="https://blog.yoursmartcv.com/en/" />
	  <link rel="alternate" hreflang="de" href="https://blog.yoursmartcv.com/de/" />
	  <link rel="alternate" hreflang="x-default" href="https://blog.yoursmartcv.com/en/" />
	</head>
  <body>
    <Header />

    <main class="page">
      <section class="hero">
        <h1>CV & ATS Guides</h1>
        <p>
          Practical guides to beat ATS, tailor your CV with AI, and write strong
          cover letters.
        </p>
      </section>

      <section class="grid">
        {posts.map((post) => (
          <a class="card" href={`/en/blog/${getSlug(post)}/`}>
            <p class="category">{post.data.category || "ATS & CV"}</p>
            <h2>{post.data.title}</h2>
            <p class="excerpt">{post.data.excerpt || post.data.description}</p>
            <span class="readmore">Read guide →</span>
          </a>
        ))}
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    background: #ffffff;
    color: #0f172a;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  .page {
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 64px 16px 48px;
    overflow-x: hidden;
  }

  .hero {
    text-align: center;
    margin-bottom: 40px;
  }

  .hero h1 {
    margin: 0 0 12px;
    font-size: 36px;
    line-height: 1.15;
    font-weight: 600;
    color: #0f172a;
    letter-spacing: -0.02em;
    overflow-wrap: anywhere;
  }

  .hero p {
    margin: 0 auto;
    max-width: 680px;
    font-size: 15px;
    line-height: 1.7;
    color: #64748b;
    overflow-wrap: anywhere;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    width: 100%;
    max-width: 100%;
  }

  .card {
    display: block;
    width: 100%;
    min-width: 0;
    max-width: 100%;
    text-decoration: none;
    text-align: left;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 15px;
    padding: 18px;
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.04);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    overflow: hidden;
  }

  .card:hover {
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    transform: translateY(-1px);
  }

  .category {
    margin: 0 0 8px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #64748b;
    overflow-wrap: anywhere;
  }

  .card h2 {
    margin: 0 0 10px;
    font-size: 17px;
    line-height: 1.45;
    font-weight: 600;
    color: #0f172a;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  .excerpt {
    margin: 0 0 14px;
    font-size: 13px;
    line-height: 1.65;
    color: #64748b;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  .readmore {
    font-size: 12px;
    font-weight: 600;
    color: #312e81;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .page {
      padding: 40px 16px 36px;
    }

    .hero {
      margin-bottom: 28px;
    }

    .hero h1 {
      font-size: 30px;
    }

    .hero p {
      font-size: 14px;
    }

    .grid {
      gap: 16px;
    }

    .card {
      padding: 16px;
      border-radius: 14px;
    }

    .card h2 {
      font-size: 16px;
    }

    .excerpt {
      font-size: 13px;
    }
  }
</style>