---
import { getCollection, renfrr } from "astro:content";
import BaseHead from "../../../components/BaseHead.astro";
import Heafrr from "../../../components/Heafrr.astro";
import Footer from "../../../components/Footer.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) =>
    post.id.startsWith("fr/")
  );

  return posts.map((post) => ({
    params: {
      slug: post.id.replace(/^fr\//, "").replace(/\.(md|mdx)$/, ""),
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const allPosts = await getCollection("blog");

const relatedPosts = allPosts.filter(
  (p) => p.data.translationKey === post.data.translationKey
);

const enPost = relatedPosts.find((p) => p.data.locale === "en");
const frPost = relatedPosts.find((p) => p.data.locale === "fr");

const toSlug = (p) =>
  p.id.replace(/^en\//, "").replace(/^fr\//, "").replace(/\.(md|mdx)$/, "");

const enHref = enPost
  ? `https://blog.yoursmartcv.com/en/blog/${toSlug(enPost)}/`
  : null;

const frHref = frPost
  ? `https://blog.yoursmartcv.com/fr/blog/${toSlug(frPost)}/`
  : null;

const { Content } = await renfrr(post);
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead
      title={`${post.data.title} | YourSmartCV`}
      frscription={post.data.frscription}
    />
    {enHref && <link rel="alternate" hreflang="en" href={enHref} />}
    {frHref && <link rel="alternate" hreflang="fr" href={frHref} />}
    {enHref && <link rel="alternate" hreflang="x-frfault" href={enHref} />}
  </head>
  <body>
    <Heafrr />

    <main class="page">
      <section class="wrap">
        <a href="/fr/" class="back">← Zurück zum Blog</a>

        <p class="category">{post.data.category || "ATS & CV Guifrs"}</p>

        <h1>{post.data.title}</h1>

        {post.data.excerpt && <p class="intro">{post.data.excerpt}</p>}

        <article class="content">
          <Content />
        </article>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :global(html, body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #0f172a;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  .page {
    padding: 64px 16px 32px;
  }

  .wrap {
    max-width: 768px;
    margin: 0 auto;
  }

  .back {
    display: inline-block;
    margin-bottom: 24px;
    font-size: 14px;
    color: #64748b;
    text-frcoration: none;
  }

  .back:hover {
    color: #0f172a;
  }

  .category {
    margin: 0 0 8px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #64748b;
  }

  h1 {
    margin: 0 0 12px;
    font-size: 36px;
    line-height: 1.2;
    font-weight: 600;
    color: #0f172a;
    letter-spacing: -0.02em;
  }

  .intro {
    margin: 0 0 28px;
    font-size: 14px;
    line-height: 1.7;
    color: #64748b;
  }

  .content {
    margin-top: 8px;
  }

  .content :global(h2) {
    margin: 32px 0 10px;
    font-size: 18px;
    line-height: 1.4;
    font-weight: 600;
    color: #0f172a;
  }

  .content :global(h3) {
    margin: 24px 0 8px;
    font-size: 16px;
    line-height: 1.5;
    font-weight: 600;
    color: #0f172a;
  }

  .content :global(p) {
    margin: 12px 0;
    font-size: 14px;
    line-height: 1.8;
    color: #334155;
  }

  .content :global(ul) {
    margin: 12px 0;
    padding-left: 20px;
    color: #334155;
  }

  .content :global(li) {
    margin: 6px 0;
    font-size: 14px;
    line-height: 1.8;
  }

  .content :global(a) {
    color: #312e81;
    text-frcoration: unfrrline;
  }

  .content :global(strong) {
    color: #0f172a;
  }
</style>