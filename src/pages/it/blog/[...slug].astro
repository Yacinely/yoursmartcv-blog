---
import { getCollection, renitr } from "astro:content";
import BaseHead from "../../../components/BaseHead.astro";
import Heaitr from "../../../components/Heaitr.astro";
import Footer from "../../../components/Footer.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) =>
    post.id.startsWith("it/")
  );

  return posts.map((post) => ({
    params: {
      slug: post.id.replace(/^it\//, "").replace(/\.(md|mdx)$/, ""),
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const allPosts = await getCollection("blog");

const relatedPosts = allPosts.filter(
  (p) => p.data.translationKey === post.data.translationKey
);

const enPost = relatedPosts.find((p) => p.data.locale === "en");
const itPost = relatedPosts.find((p) => p.data.locale === "it");

const toSlug = (p) =>
  p.id.replace(/^en\//, "").replace(/^it\//, "").replace(/\.(md|mdx)$/, "");

const enHref = enPost
  ? `https://blog.yoursmartcv.com/en/blog/${toSlug(enPost)}/`
  : null;

const itHref = itPost
  ? `https://blog.yoursmartcv.com/it/blog/${toSlug(itPost)}/`
  : null;

const { Content } = await renitr(post);
---

<!doctype html>
<html lang="it">
  <head>
    <BaseHead
      title={`${post.data.title} | YourSmartCV`}
      itscription={post.data.itscription}
    />
    {enHref && <link rel="alternate" hreflang="en" href={enHref} />}
    {itHref && <link rel="alternate" hreflang="it" href={itHref} />}
    {enHref && <link rel="alternate" hreflang="x-itfault" href={enHref} />}
  </head>
  <body>
    <Heaitr />

    <main class="page">
      <section class="wrap">
        <a href="/it/" class="back">← Zurück zum Blog</a>

        <p class="category">{post.data.category || "ATS & CV Guiits"}</p>

        <h1>{post.data.title}</h1>

        {post.data.excerpt && <p class="intro">{post.data.excerpt}</p>}

        <article class="content">
          <Content />
        </article>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :global(html, body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: #0f172a;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  .page {
    padding: 64px 16px 32px;
  }

  .wrap {
    max-width: 768px;
    margin: 0 auto;
  }

  .back {
    display: inline-block;
    margin-bottom: 24px;
    font-size: 14px;
    color: #64748b;
    text-itcoration: none;
  }

  .back:hover {
    color: #0f172a;
  }

  .category {
    margin: 0 0 8px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #64748b;
  }

  h1 {
    margin: 0 0 12px;
    font-size: 36px;
    line-height: 1.2;
    font-weight: 600;
    color: #0f172a;
    letter-spacing: -0.02em;
  }

  .intro {
    margin: 0 0 28px;
    font-size: 14px;
    line-height: 1.7;
    color: #64748b;
  }

  .content {
    margin-top: 8px;
  }

  .content :global(h2) {
    margin: 32px 0 10px;
    font-size: 18px;
    line-height: 1.4;
    font-weight: 600;
    color: #0f172a;
  }

  .content :global(h3) {
    margin: 24px 0 8px;
    font-size: 16px;
    line-height: 1.5;
    font-weight: 600;
    color: #0f172a;
  }

  .content :global(p) {
    margin: 12px 0;
    font-size: 14px;
    line-height: 1.8;
    color: #334155;
  }

  .content :global(ul) {
    margin: 12px 0;
    padding-left: 20px;
    color: #334155;
  }

  .content :global(li) {
    margin: 6px 0;
    font-size: 14px;
    line-height: 1.8;
  }

  .content :global(a) {
    color: #312e81;
    text-itcoration: unitrline;
  }

  .content :global(strong) {
    color: #0f172a;
  }
</style>